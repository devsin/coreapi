NAME=core
ENV=dev
PORT=8080
WEB_URL=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=core
DB_USERNAME=core
DB_PASSWORD=core
DB_SSL=require

# Storage
STORAGE_ACCOUNT_ID=
STORAGE_ACCESS_KEY_ID=
STORAGE_ACCESS_KEY_SECRET=
STORAGE_BUCKET=core-dev-uploads
STORAGE_PUBLIC_URL=https://cdn-dev.example.com

# JWT
JWT_JWKS_URL=https://{project_id}.supabase.co/auth/v1/.well-known/jwks.json

# Log
LOG_LEVEL=debug
LOG_FORMAT=text

# CORS
CORS_ALLOWED_ORIGINS=*

# Discord (optional)
DISCORD_CONTACT_WEBHOOK_URL=